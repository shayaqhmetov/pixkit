{
    "name": "@pixkit/react",
    "version": "0.4.2",
    "description": "Pixel-art themed React UI components",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "styles",
        "assets",
        "README.md"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./index.css": "./styles/index.css",
        "./variables.css": "./styles/variables.css",
        "./buttons.css": "./styles/buttons.css",
        "./accordion.css": "./styles/accordion.css",
        "./avatar.css": "./styles/avatar.css",
        "./badge.css": "./styles/badge.css",
        "./breadcrumb.css": "./styles/breadcrumb.css",
        "./card.css": "./styles/card.css",
        "./checkbox.css": "./styles/checkbox.css",
        "./code-view.css": "./styles/code-view.css",
        "./dialog.css": "./styles/dialog.css",
        "./input.css": "./styles/input.css",
        "./navigation.css": "./styles/navigation.css",
        "./separator.css": "./styles/separator.css",
        "./sidebar.css": "./styles/sidebar.css",
        "./switch.css": "./styles/switch.css",
        "./tabs.css": "./styles/tabs.css",
        "./textarea.css": "./styles/textarea.css",
        "./tag.css": "./styles/tag.css",
        "./alert.css": "./styles/alert.css",
        "./progress.css": "./styles/progress.css",
        "./stat-card.css": "./styles/stat-card.css",
        "./empty-state.css": "./styles/empty-state.css",
        "./table.css": "./styles/table.css",
        "./toaster.css": "./styles/toaster.css",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsup"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "dependencies": {
        "@pixkit/tokens": "workspace:*",
        "clsx": "^2.1.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.12",
        "@types/react-dom": "^19.0.0"
    },
    "keywords": [
        "react",
        "components",
        "ui",
        "pixel-art",
        "retro",
        "design-system"
    ],
    "author": "Ruslan Shayakhmetov",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/shayaqhmetov/pixkit.git",
        "directory": "packages/react"
    },
    "bugs": {
        "url": "https://github.com/shayaqhmetov/pixkit/issues"
    },
    "homepage": "https://github.com/shayaqhmetov/pixkit#readme",
    "publishConfig": {
        "access": "public"
    }
}
