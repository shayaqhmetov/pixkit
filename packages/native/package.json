{
    "name": "@pixkit/native",
    "version": "0.4.1",
    "description": "Pixel-art themed React Native UI components",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "src/assets",
        "assets",
        "react-native.config.js",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-native": ">=0.74",
        "@pixkit/tokens": "workspace:*"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/react": "^19.1.12"
    },
    "keywords": [
        "react-native",
        "components",
        "ui",
        "pixel-art",
        "retro",
        "design-system"
    ],
    "author": "Ruslan Shayakhmetov",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/shayaqhmetov/pixkit.git",
        "directory": "packages/native"
    },
    "bugs": {
        "url": "https://github.com/shayaqhmetov/pixkit/issues"
    },
    "homepage": "https://github.com/shayaqhmetov/pixkit#readme",
    "publishConfig": {
        "access": "public"
    }
}
